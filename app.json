{
  "expo": {
    "name": "Robot Arm Control",
    "slug": "robot-arm-control",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9091fa5c-48ff-469e-946f-2b6a944a2519"
      }
    },
    "android": {
      "package": "com.chaitu6.robotarmcontrol"
    }
  }
}
